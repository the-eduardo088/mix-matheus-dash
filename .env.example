# Copie para `.env` e ajuste. O `.env` é ignorado pelo git — nunca versione senha.
#
#   cp .env.example .env

# ── Banco ───────────────────────────────────────────────────────────────────
POSTGRES_USER=mix
POSTGRES_PASSWORD=mix_dev
POSTGRES_DB=mix_painel
POSTGRES_PORT=5432

# Usada pela aplicação e pelos scripts de migração.
# Na VPS, troque a senha e mantenha o host em 127.0.0.1 (o banco não deve
# escutar na internet).
DATABASE_URL=postgresql://mix:mix_dev@127.0.0.1:5432/mix_painel

# ── Arquivos ────────────────────────────────────────────────────────────────
# Pasta onde ficam os anexos (imagem, vídeo, PDF). Precisa existir e ser
# gravável pelo processo do Node. Na VPS, aponte para um volume com espaço
# sobrando e inclua no backup junto com o pg_dump.
UPLOADS_DIR=./uploads
